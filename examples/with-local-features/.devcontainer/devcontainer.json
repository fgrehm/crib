// Project demonstrating local devcontainer Features.
{
  "name": "with-local-features",
  "image": "docker.io/library/ubuntu:24.04",
  "features": {
    "./features/node": {}
  },
  "overrideCommand": true,
  "remoteUser": "root",
  "remoteEnv": {
    "CRIB_EXAMPLE": "with-local-features"
  },
  "postCreateCommand": "node --version"
}
