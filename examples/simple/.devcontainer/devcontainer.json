// Simple crib example using a plain Debian image.
{
  "name": "simple",
  "image": "docker.io/library/debian:12-slim",
  "overrideCommand": true,
  "remoteUser": "root",
  "remoteEnv": {
    "CRIB_EXAMPLE": "simple"
  },
  "postCreateCommand": "echo '==> container ready. try: crib exec -- bash'"
}
