#!/bin/bash
set -e

staged_go_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$staged_go_files" ]; then
  exit 0
fi

echo "Formatting staged Go files..."
go tool golangci-lint fmt $staged_go_files
git add -- $staged_go_files
echo "Done"

echo "Running linter..."
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  go tool golangci-lint run --new-from-rev=HEAD --fix
else
  go tool golangci-lint run --fix $staged_go_files
fi
git add -- $staged_go_files
echo "Done"

echo "Running gocyclo..."
out=$(go tool gocyclo -over 30 -ignore '_test\.go$' . || true)
if [ -n "$out" ]; then
  echo "Functions exceeding complexity threshold of 30:"
  echo "$out"
  exit 1
fi
echo "Done"
